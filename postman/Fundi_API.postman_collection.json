    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api","v1","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+10000000001\",\n  \"password\": \"password\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch(e){}",
                  "if (json.token) { pm.environment.set('token', json.token); pm.collectionVariables.set('token', json.token); }",
                  "pm.test('Login success', function(){ pm.expect(pm.response.code).to.be.oneOf([200,201]); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": { "raw": "{{base_url}}/api/v1/auth/logout", "host": ["{{base_url}}"], "path": ["api","v1","auth","logout"] } }
        },
        {
          "name": "Me",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/api/v1/auth/user", "host": ["{{base_url}}"], "path": ["api","v1","auth","user"] } }
        }
      ]
